# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly force LF for web source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.env* text eol=lf

# Binary files — no line ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.webp binary
*.woff binary
*.woff2 binary
*.glb  binary
*.gltf text eol=lf
